#!/bin/bash
# FileSqueeze pre-commit hook
# Runs ruff type checking and smoke tests to ensure commits don't break functionality

set -e  # Exit on error

echo "🔍 Running Ruff type checking..."

# Run ruff type checking
if ruff check . --select ANN; then
    echo "✅ Type checking passed"
else
    echo "❌ Type checking failed - commit rejected"
    echo ""
    echo "Ruff found type annotation issues. Please fix them before committing."
    echo "Run 'ruff check . --select ANN' for details, or 'ruff check . --fix' to auto-fix."
    exit 1
fi

echo "🔥 Running FileSqueeze smoke tests..."

# Run smoke tests with quiet output
if pytest tests/smoke/ -q; then
    echo "✅ Smoke tests passed - commit approved"
    exit 0
else
    echo "❌ Smoke tests failed - commit rejected"
    echo ""
    echo "Smoke tests check for critical system issues that users cannot fix themselves."
    echo "Please fix the failing tests before committing."
    echo ""
    echo "Run 'pytest tests/smoke/ -v' to see detailed failure information."
    exit 1
fi